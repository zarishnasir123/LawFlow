PORT=5000
NODE_ENV=development
# Origin used for OAuth redirects, password-reset links, etc. (always single).
FRONTEND_URL=http://localhost:5173
# Comma-separated list of origins allowed by CORS. Main app + standalone admin panel.
FRONTEND_URLS=http://localhost:5173,http://localhost:5174

DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/lawflow_db
SUPPORTED_TEHSILS=Gujranwala,Gujranwala City & Sadar,Kamoke,Nowshera Virkan
ALLOWED_CNIC_PREFIXES=

# LawFlow sender email. User registration email is dynamic; it is NOT written here.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
EMAIL_LOGO_URL=
EMAIL_OTP_EXPIRES_MINUTES=1
SMTP_TIMEOUT_MS=8000
EMAIL_DEBUG=false

JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret

ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
SESSION_REFRESH_TOKEN_EXPIRES_IN=8h
REMEMBER_ME_REFRESH_TOKEN_EXPIRES_IN=7d
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false

# Supabase private storage for lawyer verification documents.
# Bucket "lawyer-verification-documents" must exist as PRIVATE in Supabase Storage.
# Service role key must NEVER be exposed to the frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_LAWYER_BUCKET=lawyer-verification-documents
SUPABASE_PREVIEW_URL_EXPIRES_IN=900

SUPABASE_WEBHOOK_SECRET=<any-long-random-string>
