PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# Allowed CORS origins (comma-separated). Includes the admin panel on 5174.
FRONTEND_URLS=http://localhost:5173,http://localhost:5174

DATABASE_URL=postgresql://postgres:password@localhost:5432/lawflow_db
SUPPORTED_TEHSILS=Gujranwala,Gujranwala City & Sadar,Kamoke,Nowshera Virkan
ALLOWED_CNIC_PREFIXES=

# LawFlow sender email (Gmail SMTP). Use a Gmail App Password, not the account password.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-sender@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM=LawFlow <your-sender@gmail.com>
EMAIL_LOGO_URL=
EMAIL_OTP_EXPIRES_MINUTES=1
SMTP_TIMEOUT_MS=8000
EMAIL_DEBUG=false

JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret

ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
SESSION_REFRESH_TOKEN_EXPIRES_IN=8h
REMEMBER_ME_REFRESH_TOKEN_EXPIRES_IN=7d
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_LAWYER_BUCKET=lawyer-verification-documents
SUPABASE_PREVIEW_URL_EXPIRES_IN=900

SUPABASE_WEBHOOK_SECRET=your-supabase-webhook-secret

# Safepay (Pakistani payment gateway) — sandbox/test mode.
# Get these from the Safepay sandbox dashboard > Developers > API.
SAFEPAY_API_KEY=
SAFEPAY_SECRET_KEY=
SAFEPAY_WEBHOOK_SECRET=
SAFEPAY_ENVIRONMENT=sandbox
SAFEPAY_CURRENCY=PKR
# Public HTTPS base Safepay can reach for the payment return + webhook.
# In dev this is an ngrok tunnel to the backend (port 5000); Safepay can't call localhost.
PUBLIC_API_URL=https://your-ngrok-subdomain.ngrok-free.app
