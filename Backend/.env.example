PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/lawflow_db
SUPPORTED_TEHSILS=Gujranwala
ALLOWED_CNIC_PREFIXES=

# LawFlow sender email. User registration email is dynamic; it is NOT written here.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
EMAIL_LOGO_URL=
EMAIL_OTP_EXPIRES_MINUTES=1
SMTP_TIMEOUT_MS=8000
EMAIL_DEBUG=false

JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret

ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
SESSION_REFRESH_TOKEN_EXPIRES_IN=8h
REMEMBER_ME_REFRESH_TOKEN_EXPIRES_IN=7d
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
