# Committed defaults for the Backend test environment. NO SECRETS in this file.
#
# Each developer also creates Backend/.env.test.local (gitignored) containing
# their local throwaway database:
#
#   TEST_DATABASE_URL=postgresql://postgres:YOUR_LOCAL_PASSWORD@localhost:5432/lawflow_test
#
# The guard in tests/setup/guard.js refuses anything that is not a local
# database ending in _test / _e2e — the real Supabase database can never be hit.

JWT_ACCESS_SECRET=test-access-secret
JWT_REFRESH_SECRET=test-refresh-secret
BCRYPT_ROUNDS=4
